#!/usr/bin/env -S bash -euo pipefail
# Quick development helper for the Agoramesh workspace.

usage() {
    cat <<EOF
Usage: ./dev <command>

Commands:
  check       Run cargo check across the workspace
  test        Run all workspace tests
  lint        Run clippy and rustfmt checks
  fmt         Format the workspace
  ci          Run the full CI-quality check
EOF
}

cmd_check() {
    cargo check --workspace --all-targets
}

cmd_test() {
    cargo test --workspace --all-targets
}

cmd_lint() {
    cargo fmt --check
    cargo clippy --workspace --all-targets -- -D warnings
}

cmd_fmt() {
    cargo fmt
}

cmd_ci() {
    cmd_fmt
    cmd_check
    cmd_lint
    cmd_test
}

main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 1
    fi

    case "$1" in
        check) cmd_check ;;
        test) cmd_test ;;
        lint) cmd_lint ;;
        fmt) cmd_fmt ;;
        ci) cmd_ci ;;
        *) usage; exit 1 ;;
    esac
}

main "$@"
